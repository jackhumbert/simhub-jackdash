<UserControl
    x:Class="User.CornerSpeed.iRacingCornerSpeedRowItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:user="clr-namespace:User.CornerSpeed"
    d:DataContext="{d:DesignInstance Type=user:CornerViewModel}"
    Background="Transparent"
    mc:Ignorable="d">
    <StackPanel Margin="0,0,0,0" Orientation="Vertical">
        <StackPanel.Resources>
            <Style x:Key="BaseSpeedStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="Chivo Mono" />
                <Setter Property="TextAlignment" Value="Right" />
                <Setter Property="Padding" Value="8,4,8,4" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="Opacity" Value="1.0" />
            </Style>
            <Style
                x:Key="SpeedStyle"
                BasedOn="{StaticResource BaseSpeedStyle}"
                TargetType="{x:Type TextBlock}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Latest}" Value="False">
                        <Setter Property="Opacity" Value="0.5" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style
                x:Key="ActiveSpeedStyle"
                BasedOn="{StaticResource BaseSpeedStyle}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource TextHighlightBrush}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                        <Setter Property="Foreground" Value="White" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Latest}" Value="False">
                        <Setter Property="Opacity" Value="0.5" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style
                x:Key="SpeedDeltaStyle"
                BasedOn="{StaticResource BaseSpeedStyle}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="Visibility" Value="Hidden" />
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsNewEntry}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <MultiDataTrigger.Setters>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger.Setters>
                    </MultiDataTrigger>
                    <DataTrigger Binding="{Binding Latest}" Value="False">
                        <Setter Property="Opacity" Value="0.8" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style
                x:Key="ActiveSpeedDeltaStyle"
                BasedOn="{StaticResource SpeedStyle}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="Visibility" Value="Hidden" />
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsNewEntry}" Value="False" />
                            <!--  Condition Binding="{Binding IsActive}" Value="False" /  -->
                        </MultiDataTrigger.Conditions>
                        <MultiDataTrigger.Setters>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger.Setters>
                    </MultiDataTrigger>
                    <DataTrigger Binding="{Binding Latest}" Value="False">
                        <Setter Property="Opacity" Value="0.8" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="BaseTimeStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="Chivo Mono" />
                <Setter Property="TextAlignment" Value="Right" />
                <Setter Property="Padding" Value="4,0,4,0" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>
            <Style
                x:Key="TimeStyle"
                BasedOn="{StaticResource BaseTimeStyle}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource TextHighlightBrush}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Latest}" Value="False">
                        <Setter Property="Opacity" Value="0.5" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                        <Setter Property="Foreground" Value="White" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style
                x:Key="TimeDeltaStyle"
                BasedOn="{StaticResource BaseTimeStyle}"
                TargetType="{x:Type TextBlock}">
                <!--  Setter Property="Visibility" Value="Hidden" /  -->
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsNewEntry}" Value="True" />
                            <!--  Condition Binding="{Binding IsActive}" Value="False" /  -->
                        </MultiDataTrigger.Conditions>
                        <MultiDataTrigger.Setters>
                            <Setter Property="Visibility" Value="Hidden" />
                        </MultiDataTrigger.Setters>
                    </MultiDataTrigger>
                    <DataTrigger Binding="{Binding Latest}" Value="False">
                        <Setter Property="Opacity" Value="0.8" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </StackPanel.Resources>
        <Grid Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="370" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <Grid Background="Transparent">
                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="{x:Type StackPanel}">
                            <Style.Resources>
                                <Style BasedOn="{StaticResource ButtonStyle}" TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=IsMouseOver}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Style.Resources>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock
                        Margin="4,4,0,4"
                        FontFamily="Inter"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextHighlightBrush}"
                        LineHeight="14.4"
                        Text="{Binding TurnName}"
                        TextAlignment="Left" />
                    <Button
                        Margin="4,0,0,0"
                        Padding="6,3"
                        Click="Delete_Click"
                        Content="Delete"
                        FontSize="10" />
                </StackPanel>
            </Grid>
            <Grid
                Grid.Column="1"
                Grid.ColumnSpan="1"
                Margin="0,0,4,0">
                <UniformGrid Columns="6">
                    <TextBlock Style="{StaticResource ActiveSpeedStyle}" Text="{Binding MinSpeed, Converter={StaticResource SpeedConverter}}" />
                    <TextBlock
                        Foreground="{Binding MinSpeedDelta, Converter={StaticResource DeltaColorConverter}}"
                        Style="{StaticResource SpeedDeltaStyle}"
                        Text="{Binding MinSpeedDelta, Converter={StaticResource SpeedDeltaConverter}}" />

                    <Border
                        Margin="0,0,4,0"
                        Padding="4"
                        Background="{StaticResource BlackboxBackgroundBrush1}"
                        CornerRadius="4,4,4,4">
                        <TextBlock
                            Foreground="{Binding ApexDelta, Converter={StaticResource DurationDeltaColorConverter}}"
                            Style="{StaticResource TimeDeltaStyle}"
                            Text="{Binding ApexDelta, Converter={StaticResource TimeSpanDeltaFormatter}}" />
                    </Border>
                    <TextBlock
                        Margin="4"
                        Foreground="{Binding ApexDistDelta, Converter={StaticResource DeltaColorConverter}}"
                        Style="{StaticResource TimeDeltaStyle}"
                        Text="{Binding ApexDistDelta, Converter={StaticResource MeterDeltaConverter}}" />

                    <TextBlock Style="{StaticResource ActiveSpeedStyle}" Text="{Binding EndSpeed, Converter={StaticResource SpeedConverter}}" />
                    <TextBlock
                        Foreground="{Binding EndSpeedDelta, Converter={StaticResource DeltaColorConverter}}"
                        Style="{StaticResource ActiveSpeedDeltaStyle}"
                        Text="{Binding EndSpeedDelta, Converter={StaticResource SpeedDeltaConverter}}" />
                </UniformGrid>
            </Grid>
            <Border
                Grid.Column="2"
                Margin="0,0,4,0"
                Padding="4"
                Background="{StaticResource BlackboxBackgroundBrush1}"
                CornerRadius="4,4,4,4">
                <UniformGrid Columns="2">
                    <StackPanel FlowDirection="RightToLeft" Orientation="Horizontal">
                        <TextBlock x:Name="Duration" Text="{Binding Duration, Converter={StaticResource TimeSpanFormatter}, Mode=OneWay}">
                            <TextBlock.Style>
                                <Style BasedOn="{StaticResource TimeStyle}" TargetType="{x:Type TextBlock}">
                                    <Setter Property="Padding" Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WasShortestDuration}" Value="True">
                                            <Setter Property="Foreground" Value="#B066FF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style BasedOn="{StaticResource TimeStyle}" TargetType="{x:Type TextBlock}">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Text" Value="*" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WasShortestDuration}" Value="True">
                                            <Setter Property="Foreground" Value="#B066FF" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsInvalid}" Value="False">
                                            <Setter Property="Text" Value="" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock
                        Foreground="{Binding DurationDelta, Converter={StaticResource DurationDeltaColorConverter}}"
                        Style="{StaticResource TimeDeltaStyle}"
                        Text="{Binding DurationDelta, Converter={StaticResource TimeSpanDeltaFormatter}}" />
                </UniformGrid>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
