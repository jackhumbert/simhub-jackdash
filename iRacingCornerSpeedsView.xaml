<UserControl
    x:Class="User.CornerSpeed.iRacingCornerSpeedsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:User.CornerSpeed"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:user="clr-namespace:User.CornerSpeed"
    d:DataContext="{d:DesignInstance Type=local:iRacingCornerSpeeds}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/User.CornerSpeed;component/App.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ContentControl
        x:Name="iRacingBorder"
        Background="{StaticResource BlackboxBackgroundBrush}"
        Style="{StaticResource BlackboxControlStyle}">
        <StackPanel Orientation="Vertical">
            <Grid
                Background="Transparent"
                MouseDown="iRacingBorder_MouseDown"
                MouseMove="iRacingBorder_MouseMove"
                MouseUp="iRacingBorder_MouseUp">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="4,0,0,0"
                        FontFamily="Exo 2"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextHighlightBrush}"
                        LineHeight="14.4"
                        Text="Corner Speeds " />
                    <TextBlock
                        FontFamily="Exo 2"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextHighlightBrush}"
                        LineHeight="14.4"
                        Text="{Binding Settings.Mode, Converter={StaticResource ComparisonModeConverter}}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Border
                        Margin="0,0,4,0"
                        Padding="2"
                        Background="{StaticResource BlackboxBackgroundBrush1}"
                        BorderBrush="{StaticResource BlackboxBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Resources>
                                <ControlTemplate x:Key="RadioButton" TargetType="{x:Type RadioButton}">
                                    <Border
                                        Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                        <TextBlock Text="{TemplateBinding Content}" />
                                    </Border>
                                </ControlTemplate>
                                <Style TargetType="{x:Type RadioButton}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template" Value="{StaticResource RadioButton}" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="Margin" Value="-2" />
                                    <Setter Property="Foreground" Value="{StaticResource BlackboxBorderBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Trigger.Setters>
                                                <Setter Property="Background" Value="#10FFFFFF" />
                                                <Setter Property="Foreground" Value="{StaticResource TextFadedBrush}" />
                                            </Trigger.Setters>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.Setters>
                                                <Setter Property="Foreground" Value="{StaticResource TextFadedBrush}" />
                                            </Trigger.Setters>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Trigger.Setters>
                                                <Setter Property="Background" Value="{StaticResource BlackboxBackgroundBrush0.Inverted}" />
                                            </Trigger.Setters>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Resources>
                            <RadioButton
                                Content="Lap"
                                GroupName="WholeLap"
                                IsChecked="{Binding Path=Settings.WholeLapDeltaArray[0], Mode=TwoWay}" />
                            <RadioButton
                                Content="Corner"
                                GroupName="WholeLap"
                                IsChecked="{Binding Path=Settings.WholeLapDeltaArray[1], Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                    <Button
                        x:Name="Prev"
                        Margin="0,0,4,0"
                        Padding="6,3"
                        Click="Mode_Prev"
                        Content="&lt;"
                        Style="{StaticResource ButtonStyle}" />
                    <Button
                        x:Name="Next"
                        Margin="0,0,4,0"
                        Padding="6,3"
                        Click="Mode_Next"
                        Content="&gt;"
                        Style="{StaticResource ButtonStyle}" />
                </StackPanel>
            </Grid>
            <Grid Margin="0,5,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <!--
                    TextBlock
                    Margin="4,2,0,0"
                    HorizontalAlignment="Left"
                    FontFamily="Chivo Mono"
                    FontSize="10"
                    Foreground="White"
                    Text="{Binding Plugin.TrackId}"
                    TextAlignment="Right" /
                -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="4,0,0,0"
                        HorizontalAlignment="Left"
                        FontFamily="Inter"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextHighlightBrush}"
                        Text="Opt:"
                        TextAlignment="Left" />
                    <TextBlock
                        Margin="4,1,0,0"
                        HorizontalAlignment="Left"
                        FontFamily="Chivo Mono"
                        FontSize="12"
                        Foreground="White"
                        Text="{Binding Plugin.OptimalCornerSpeedsLap, Converter={StaticResource TimeSpanFormatter}}"
                        TextAlignment="Right" />
                </StackPanel>
                <!--
                    TextBlock
                    FontFamily="Inter"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="{StaticResource TextHighlightBrush}"
                    LineHeight="14.4"
                    Text="START"
                    TextAlignment="Center" /
                -->
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border
                        Grid.Row="1"
                        Margin="1,0,0,0"
                        BorderBrush="#10FFFFFF"
                        BorderThickness="1,1,0,0" />
                    <TextBlock
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        FontFamily="Inter"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextHighlightBrush}"
                        LineHeight="14.4"
                        Text="MIN"
                        TextAlignment="Center" />
                    <Border
                        Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,0,1,0"
                        BorderBrush="#10FFFFFF"
                        BorderThickness="0,1,1,0" />
                </Grid>
                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border
                        Grid.Row="1"
                        Margin="1,0,0,0"
                        BorderBrush="#10FFFFFF"
                        BorderThickness="1,1,0,0" />
                    <TextBlock
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        FontFamily="Inter"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextHighlightBrush}"
                        LineHeight="14.4"
                        Text="END"
                        TextAlignment="Center" />
                    <Border
                        Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,0,1,0"
                        BorderBrush="#10FFFFFF"
                        BorderThickness="0,1,1,0" />
                </Grid>
                <TextBlock
                    Grid.Column="3"
                    FontFamily="Inter"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="{StaticResource TextHighlightBrush}"
                    LineHeight="14.4"
                    Text="TIME"
                    TextAlignment="Center" />
            </Grid>
            <ItemsControl ItemsSource="{Binding Path=Corners}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <user:iRacingCornerSpeedRowItem />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ContentControl>
</UserControl>
