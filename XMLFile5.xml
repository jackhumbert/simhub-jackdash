<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:models="clr-namespace:SimHub.Plugins.OutputPlugins.GraphicalDash.Models" xmlns:dopascript="clr-namespace:DopaScript;assembly=WoteverWPFControls" xmlns:circulargauge="clr-namespace:CircularGauge;assembly=CircularGauge" xmlns:editorcontrols="clr-namespace:SimHub.Plugins.OutputPlugins.EditorControls" xmlns:local="clr-namespace:SimHub.Plugins.OutputPlugins.GraphicalDash">
	<DataTemplate x:Key="selectable" DataType="{x:Type models:DrawableItem}">
		<Canvas>
			<Grid Name="ReflectedVisual" VerticalAlignment="Top" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5" Margin="{Binding Path=Position}" IsHitTestVisible="{Binding Path=IsFreezed, Converter={NotBoolConverter Invert=True}}" Width="{Binding Width}" Height="{Binding Height}">
				<UIElement.RenderTransform>
					<RotateTransform Angle="{Binding Path=Rotation}" />
				</UIElement.RenderTransform>
				<editorcontrols:EditorSelectionAdorner />
			</Grid>
		</Canvas>
	</DataTemplate>
	<DataTemplate x:Key="notselectable" DataType="{x:Type models:DrawableItem}">
		<Canvas>
			<Grid Name="ReflectedVisual" VerticalAlignment="Top" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5" Margin="{Binding Path=Position}" IsHitTestVisible="{Binding Path=IsFreezed, Converter={NotBoolConverter Invert=True}}" Width="{Binding Width}" Height="{Binding Height}">
				<UIElement.RenderTransform>
					<RotateTransform Angle="{Binding Path=Rotation}" />
				</UIElement.RenderTransform>
			</Grid>
		</Canvas>
	</DataTemplate>
	<local:SelectionTemplateSelector x:Key="templateSelector" />
	<ControlTemplate x:Key="MyItemsTemplate" TargetType="{x:Type ItemsControl}">
		<ItemsPresenter />
	</ControlTemplate>
	<DataTemplate x:Key="layer" DataType="{x:Type models:Layer}">
		<Grid IsHitTestVisible="{Binding Path=IsFreezed, Converter={NotBoolConverter Invert=True}}">
			<Grid VerticalAlignment="Top" HorizontalAlignment="Left" Background="#00FFFFFF" Margin="{Binding Path=Position}" Visibility="{Binding Path=Group, Converter={SHBoolToVisibilityConverter}}" Width="{Binding Width}" Height="{Binding Height}" />
			<Grid VerticalAlignment="Top" HorizontalAlignment="Left" Margin="{Binding Path=Position}" Visibility="{Binding Path=TemporaryUnGroup, Converter={SHBoolToVisibilityConverter}}" Width="{Binding Width}" Height="{Binding Height}">
				<Rectangle StrokeDashArray="4 4" StrokeThickness="2" Stroke="#FFFFA500" Margin="-8">
					<UIElement.Effect>
						<DropShadowEffect Color="Black" Direction="0" ShadowDepth="0" BlurRadius="4" Opacity="1" />
					</UIElement.Effect>
				</Rectangle>
			</Grid>
			<Grid Visibility="{Binding Path=ShowSelection, Converter={SHBoolToVisibilityConverter Invert=True}}">
				<ItemsControl Name="icLayer" Template="{StaticResource MyItemsTemplate}" ItemTemplateSelector="{StaticResource templateSelector}" ItemsSource="{Binding Path=Childrens}" Visibility="{Binding Visible, Converter={SHBoolToVisibilityConverter}}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="{Binding Owner.Editor.IsEditMode, Converter={SHBoolToVisibilityConverter}}" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
				</ItemsControl>
			</Grid>
			<Grid Name="ReflectedVisual" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#00FFFFFF" RenderTransformOrigin="0.5,0.5" Margin="{Binding Path=Position}" Visibility="{Binding Path=ShowSelection, Converter={SHBoolToVisibilityConverter}}" IsHitTestVisible="{Binding Path=IsFreezed, Converter={NotBoolConverter Invert=True}}" Width="{Binding Width}" Height="{Binding Height}">
				<editorcontrols:EditorSelectionAdorner />
			</Grid>
		</Grid>
	</DataTemplate>
	<DataTemplate x:Key="container" DataType="{x:Type models:ContainerItemBase}">
		<Grid IsHitTestVisible="{Binding Path=IsFreezed, Converter={NotBoolConverter Invert=True}}" Margin="{Binding Path=Position}">
			<Grid VerticalAlignment="Top" HorizontalAlignment="Left" Visibility="{Binding Path=TemporaryUnGroup, Converter={SHBoolToVisibilityConverter}}" Width="{Binding Width}" Height="{Binding Height}">
				<Rectangle StrokeDashArray="4 4" StrokeThickness="2" Stroke="#FFFFA500" Margin="-8">
					<UIElement.Effect>
						<DropShadowEffect Color="Black" Direction="0" ShadowDepth="0" BlurRadius="4" Opacity="1" />
					</UIElement.Effect>
				</Rectangle>
			</Grid>
			<Grid Visibility="{Binding Path=ShowSelection, Converter={SHBoolToVisibilityConverter Invert=True}}">
				<ItemsControl Name="icLayer" Template="{StaticResource MyItemsTemplate}" ItemTemplateSelector="{StaticResource templateSelector}" ItemsSource="{Binding Path=Childrens}" Visibility="{Binding Visible, Converter={SHBoolToVisibilityConverter}}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="{Binding Owner.Editor.IsEditMode, Converter={SHBoolToVisibilityConverter}}" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
				</ItemsControl>
			</Grid>
			<Grid Name="ReflectedVisual" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#00FFFFFF" RenderTransformOrigin="0.5,0.5" Visibility="{Binding Path=ShowSelection, Converter={SHBoolToVisibilityConverter}}" IsHitTestVisible="{Binding Path=IsFreezed, Converter={NotBoolConverter Invert=True}}" Width="{Binding Width}" Height="{Binding Height}">
				<editorcontrols:EditorSelectionAdorner />
			</Grid>
		</Grid>
	</DataTemplate>
</ResourceDictionary>