<UserControl
    x:Class="User.CornerSpeed.CarLoadPendulum"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:User.CornerSpeed"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:CarLoadPendulumItem}"
    d:DesignHeight="160"
    d:DesignWidth="160"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/User.CornerSpeed;component/App.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Canvas Background="Transparent">
        <Canvas x:Name="TraceLayer" IsHitTestVisible="False" />
        <Ellipse
            x:Name="Pivot"
            Width="8"
            Height="8"
            Fill="{StaticResource TextHighlightBrush}" />
        <Line
            x:Name="PendulumRod"
            Stroke="{StaticResource TextBrush}"
            StrokeThickness="2" />
        <Ellipse
            x:Name="PendulumMass"
            Width="24"
            Height="24"
            Fill="{StaticResource TextHighlightBrush}" />
    </Canvas>
</UserControl>
